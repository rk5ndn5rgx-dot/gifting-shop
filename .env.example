# Copy to .env and fill with your real values
# Never commit .env to git

# MongoDB
MONGODB_URI=mongodb://localhost:27017
DB_NAME=rayd_ent

# Admin access
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeMeStrong123!
ADMIN_PIN=1234

# Business
SELLER_USERNAME=rayd_seller
CREDITS_UNIT_USD=0.10

# Stripe (generate new keys in Dashboard; do NOT reuse leaked ones)
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_webhook_signing_secret_here

# Cloudinary (free 25GB; sign up at cloudinary.com, copy API Environment variable)
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# Firebase Admin (copy the whole JSON contents into FIREBASE_SERVICE_ACCOUNT_KEY)
FIREBASE_SERVICE_ACCOUNT_KEY={}
FIREBASE_PROJECT_ID=studio-2fb13

# SMTP (optional if you enable email flows)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-user
SMTP_PASS=your-pass
SMTP_FROM="Your App <no-reply@example.com>"

# Node.js & Server
NODE_VERSION=18.17.0
PORT=10000